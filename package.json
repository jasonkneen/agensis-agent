{
  "name": "agensis-agent-monorepo",
  "version": "0.1.26",
  "private": true,
  "description": "Open-source local agent daemon for Agensis workspaces",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "npm run check --workspace=agensis-cli",
    "test": "node --experimental-test-module-mocks --test tests/*.test.cjs tests/*.test.mjs",
    "test:unit": "vitest run tests/unit",
    "build": "npm run build --workspace=@agensis/agensis-agent",
    "pack:dry-run": "npm run pack:dry-run --workspace=@agensis/agensis-agent",
    "verify": "npm run check && npm test && npm run test:unit && npm run build && npm run pack:dry-run"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
