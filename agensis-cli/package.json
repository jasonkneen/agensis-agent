{
  "name": "agensis-cli",
  "version": "0.1.16",
  "description": "Run a local agensis workspace agent daemon. It connects to a workspace, receives @mention jobs, runs a configured coding CLI in the local folder, and posts results back to agensis.",
  "homepage": "https://agensis.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkneen/agensis.git",
    "directory": "agent/agensis-cli"
  },
  "bugs": {
    "url": "https://github.com/jasonkneen/agensis/issues"
  },
  "type": "module",
  "bin": {
    "agensis": "bin/agensis.mjs"
  },
  "exports": {
    ".": "./src/agensis.mjs"
  },
  "scripts": {
    "check": "node --check bin/agensis.mjs && node --check src/agensis.mjs && node --check src/cli.mjs && node --check src/queue.mjs && node --check src/memory.mjs",
    "link": "npm link && bun link",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run check",
    "prepublishOnly": "npm run check"
  },
  "files": [
    "bin/agensis.mjs",
    "src/agensis.mjs",
    "src/cli.mjs",
    "src/queue.mjs",
    "src/memory.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agensis",
    "workspace",
    "agent",
    "claude-code",
    "codex",
    "cursor",
    "coding-agent"
  ],
  "dependencies": {
    "ws": "^8.20.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
